# Copy this file to `.env` and replace every placeholder before deployment.

# Database / Orthanc
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
POSTGRES_USER=orthanc
POSTGRES_PASSWORD=change-me
POSTGRES_DB=orthanc

ORTHANC_DB_HOST=postgresql
ORTHANC_DB_USER=orthanc
ORTHANC_DB_PASSWORD=change-me
ORTHANC_DB_NAME=orthanc
ORTHANC_URL=http://orthanc:8042

# Django
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me-admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SECRET_KEY=change-this-in-env
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=*

# External HIS / Periksa API
PERIKSA_API_URL=http://periksaapis.com
CLINIC_ID=
PERIKSA_API_USERNAME=
PERIKSA_API_PASSWORD=

# Satu Sehat / DICOM Router
SATUSEHAT_URL=https://api-satusehat.kemkes.go.id
SATUSEHAT_ORG_ID=
SATUSEHAT_CLIENT=
SATUSEHAT_SECRET=
DCMROUTER_CALLBACK_URL=http://worklist-web:8000/worklist/api/dicom-router-callback/
